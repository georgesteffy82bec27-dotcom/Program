public class Main {

    public static double calculateGrossSalary(double basicSalary, double allowance) {
        return basicSalary + allowance;
    }

    public static double calculateNetSalary(double grossSalary, double deduction) {
        return grossSalary - deduction;
    }

    public static void main(String[] args) {
        double basicSalary = 30000;
        double allowance = 5000;
        double deduction = 2000;

        double grossSalary = Main.calculateGrossSalary(basicSalary, allowance);
        double netSalary = Main.calculateNetSalary(grossSalary, deduction);

        System.out.println("Gross Salary = " + (int)grossSalary);
        System.out.println("Net Salary = " + (int)netSalary);
    }
}
