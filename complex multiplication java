class Complex {
    int real;
    int img;

    Complex(int r, int img) {
        this.real = r;
        this.img = img; 
    }

    Complex() {
        real = 0;
        img = 0;
    }

    public Complex multiply(Complex c) {
        Complex res = new Complex();
        res.real = (this.real * c.real) - (this.img * c.img);
        res.img = (this.real * c.img) + (this.img * c.real);
        return res;
    }

    public void display() {
        System.out.println(real + " + i" + img);
    }
}

public class Main {
    public static void main(String arg[]) {
        Complex c1 = new Complex(12, 12);
        Complex c2 = new Complex(1, 2);
       
        Complex c4 = c1.multiply(c2);
        System.out.print("Multiplication Result: ");
        c4.display();
    }
}
