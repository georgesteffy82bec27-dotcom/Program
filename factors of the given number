#include <iostream>
using namespace std;

int main() {
    int num;

    cout << "Enter an integer: ";
    cin >> num;

    if(num == 0) {
        cout << "Input is zero, all numbers are factors of zero." << endl;
    } else {
        cout << "Factors of " << num << " are: ";
        int absNum = num > 0 ? num : -num;
        for(int i = 1; i <= absNum; i++) {
            if(absNum % i == 0) {
                cout << i << " ";
            }
        }
        cout << endl;
    }

    return 0;
}
