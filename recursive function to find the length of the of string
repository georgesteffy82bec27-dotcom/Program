#include <iostream>
using namespace std;

int stringLength(const char* str) {
    if (*str == '\0') {
        return 0;
    }
    return 1 + stringLength(str + 1);
}

int main() {
    const char* myString = "Hello, World!";
    
    cout << "The length of the string \"" << myString << "\" is: " 
         << stringLength(myString) << endl;
    
    const char* anotherString = "Recursion ";
    cout << "The length of \"" << anotherString << "\" is: " 
         << stringLength(anotherString) << endl;

    return 0;
}
