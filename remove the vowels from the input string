#include <iostream>
#include <string>
#include <cctype>

bool isVowel(char ch) {
    ch = std::tolower(ch); 
    return ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u';
}

std::string removeVowels(const std::string& input) {
    std::string result;
    for (char ch : input) {
        if (!isVowel(ch)) {
            result += ch; 
        }
    }
    return result;
}

int main() {
    std::string input;
    
    std::cout << "Enter a string: ";
    std::getline(std::cin, input);
    
    std::string output = removeVowels(input);
    std::cout << "String without vowels: " << output << std::endl;
    
    return 0;
}
