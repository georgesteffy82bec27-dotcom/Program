#include <iostream>
using namespace std;

int add(int a, int b) {
    while (b != 0) {
        int carry = a & b;

        a = a ^ b;

        b = carry << 1;
    }
    return a;
}

int main() {
    int num1, num2;

    cout << "Enter first number: ";
    cin >> num1;

    cout << "Enter second number: ";
    cin >> num2;

    int result = add(num1, num2);

    cout << "Sum: " << result << endl;

    return 0;
}
